{
  "extends": [
    "development"
  ],
  "hints": {
    "meta-viewport": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "user-select",
          "backdrop-filter"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 15.8",
    "not chrome <= 120",
    "not edge <= 120",
    "not ios_saf <= 17.3",
    "not opera <= 106",
    "not safari <= 17.3",
    "not samsung <= 23",
    "not and_ff <= 122",
    "not firefox <= 123"
  ]
}