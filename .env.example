# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ห้าม commit .env ขึ้น git)

# หาได้จาก https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID ของเสียงที่จะใช้อ่าน (แนะนำเสียงไทย ดูวิธีหาใน README.md)
ELEVENLABS_VOICE_ID=your_voice_id_here

# โมเดล — eleven_multilingual_v2 รองรับภาษาไทยได้ดี (ค่าเริ่มต้นถ้าไม่ตั้งบรรทัดนี้)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

PORT=3000
